# ── Resend (email alerts) ──────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender address for alert emails.
# Testing: keep onboarding@resend.dev (only delivers to your Resend account email)
# Production: set to alerts@yourdomain.com after verifying your domain in Resend
FROM_EMAIL=onboarding@resend.dev

# ── App ────────────────────────────────────────────────────────────────────────
# Public URL of your deployment — used in email unsubscribe links
# BASE_URL=https://yourdomain.com

# ── Database ───────────────────────────────────────────────────────────────────
# Absolute path to the SQLite file. Mount a Docker volume here in production.
# DB_PATH=/data/monitors.db
